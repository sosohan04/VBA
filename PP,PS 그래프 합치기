Sub CreateAllGanttCharts_WithCombined()
    Dim ws As Worksheet, wsData As Worksheet, wsIndiv As Worksheet, wsCombined As Worksheet
    Dim dictStart As Object, dictEnd As Object
    Dim lastRow As Long, i As Long
    Dim blockName As String, inPosDate As Date, weldDate As Date
    Dim varKey As Variant
    Dim rowOutput As Long, rowCombined As Long
    Dim isPP As Boolean, isPS As Boolean
    Dim chartTitle As String
    Dim chartObj As ChartObject, myChart As Chart
    Dim processedCount As Integer
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    ' 1. 기존에 생성된 보고서 시트들(개별 및 통합)이 있다면 초기화(삭제)
    For Each ws In ActiveWorkbook.Worksheets
        If InStr(1, UCase(ws.Name), "_GANTT") > 0 Or UCase(ws.Name) = "COMBINED_GANTT" Then
            ws.Delete
        End If
    Next ws
    Application.DisplayAlerts = True
    
    ' 2. 통합 차트를 그릴 'Combined_Gantt' 시트 미리 생성
    Set wsCombined = Sheets.Add(After:=Sheets(Sheets.Count))
    wsCombined.Name = "Combined_Gantt"
    wsCombined.Cells(1, 1).Value = "Block (Type)"
    wsCombined.Cells(1, 2).Value = "Start Date"
    wsCombined.Cells(1, 3).Value = "PP Duration"
    wsCombined.Cells(1, 4).Value = "PS Duration"
    rowCombined = 2
    processedCount = 0
    
    ' 3. 엑셀 파일 내의 모든 시트를 돌면서 PP, PS 데이터 처리
    For Each wsData In ActiveWorkbook.Worksheets
        isPP = InStr(1, UCase(wsData.Name), "PP") > 0
        isPS = InStr(1, UCase(wsData.Name), "PS") > 0
        
        If (isPP Or isPS) And InStr(1, UCase(wsData.Name), "GANTT") = 0 Then
            
            lastRow = wsData.Cells(wsData.Rows.Count, "B").End(xlUp).Row
            Set dictStart = CreateObject("Scripting.Dictionary")
            Set dictEnd = CreateObject("Scripting.Dictionary")
            
            ' 데이터 수집 (B열: Block, D열: 시작일, F열: 완료일)
            For i = 2 To lastRow
                blockName = Trim(wsData.Cells(i, 2).Value)
                If blockName <> "" And IsDate(wsData.Cells(i, 4).Value) And IsDate(wsData.Cells(i, 6).Value) Then
                    inPosDate = CDate(wsData.Cells(i, 4).Value)
                    weldDate = CDate(wsData.Cells(i, 6).Value)
                    
                    If Not dictStart.Exists(blockName) Then
                        dictStart.Add blockName, inPosDate
                    Else
                        If inPosDate < dictStart(blockName) Then dictStart(blockName) = inPosDate
                    End If
                    
                    If Not dictEnd.Exists(blockName) Then
                        dictEnd.Add blockName, weldDate
                    Else
                        If weldDate > dictEnd(blockName) Then dictEnd(blockName) = weldDate
                    End If
                End If
            Next i
            
            If dictStart.Count > 0 Then
                ' --- A. 개별 차트 시트 생성 로직 ---
                Set wsIndiv = Sheets.Add(After:=Sheets(Sheets.Count - 1))
                wsIndiv.Name = Left(wsData.Name, 15) & "_Gantt"
                
                wsIndiv.Cells(1, 1).Value = "Block"
                wsIndiv.Cells(1, 2).Value = "Start Date"
                wsIndiv.Cells(1, 3).Value = "Duration"
                
                rowOutput = 2
                For Each varKey In dictStart.Keys
                    ' 개별 시트에 데이터 기록
                    wsIndiv.Cells(rowOutput, 1).Value = varKey
                    wsIndiv.Cells(rowOutput, 2).Value = CDbl(dictStart(varKey))
                    wsIndiv.Cells(rowOutput, 2).NumberFormat = "yyyy-mm-dd"
                    wsIndiv.Cells(rowOutput, 3).Value = Application.WorksheetFunction.Max(1, dictEnd(varKey) - dictStart(varKey))
                    rowOutput = rowOutput + 1
                    
                    ' --- B. 통합 시트(Combined)에 데이터 누적 ---
                    ' 블록명 뒤에 (PP) 또는 (PS)를 붙여서 구분
                    wsCombined.Cells(rowCombined, 1).Value = varKey & IIf(isPP, " (PP)", " (PS)")
                    wsCombined.Cells(rowCombined, 2).Value = CDbl(dictStart(varKey))
                    wsCombined.Cells(rowCombined, 2).NumberFormat = "yyyy-mm-dd"
                    
                    If isPP Then
                        wsCombined.Cells(rowCombined, 3).Value = Application.WorksheetFunction.Max(1, dictEnd(varKey) - dictStart(varKey))
                        wsCombined.Cells(rowCombined, 4).Value = 0
                    Else
                        wsCombined.Cells(rowCombined, 3).Value = 0
                        wsCombined.Cells(rowCombined, 4).Value = Application.WorksheetFunction.Max(1, dictEnd(varKey) - dictStart(varKey))
                    End If
                    rowCombined = rowCombined + 1
                Next varKey
                
                ' 개별 차트 정렬 및 생성
                wsIndiv.Range("A1:C" & rowOutput - 1).Sort Key1:=wsIndiv.Range("A2"), Order1:=xlAscending, Header:=xlYes
                Set chartObj = wsIndiv.ChartObjects.Add(Left:=300, Top:=20, Width:=750, Height:=600)
                Set myChart = chartObj.Chart
                myChart.ChartType = xlBarStacked
                
                Do While myChart.SeriesCollection.Count > 0
                    myChart.SeriesCollection(1).Delete
                Loop
                
                With myChart.SeriesCollection.NewSeries
                    .Name = "Start Date"
                    .XValues = wsIndiv.Range("A2:A" & rowOutput - 1)
                    .Values = wsIndiv.Range("B2:B" & rowOutput - 1)
                    .Format.Fill.Visible = msoFalse
                    .Format.Line.Visible = msoFalse
                End With
                With myChart.SeriesCollection.NewSeries
                    .Name = "Duration"
                    .XValues = wsIndiv.Range("A2:A" & rowOutput - 1)
                    .Values = wsIndiv.Range("C2:C" & rowOutput - 1)
                    .Format.Fill.Visible = msoTrue
                    If isPS Then .Format.Fill.ForeColor.RGB = RGB(84, 130, 53) Else .Format.Fill.ForeColor.RGB = RGB(237, 125, 49)
                End With
                With myChart
                    .HasTitle = True
                    .ChartTitle.Text = IIf(isPP, "배관 스풀(PP) 작업 일정", "파이프 서포트(PS) 작업 일정")
                    .Axes(xlCategory).ReversePlotOrder = True
                    With .Axes(xlValue)
                        .MinimumScale = CDbl(DateSerial(2026, 3, 1))
                        .MaximumScale = CDbl(DateSerial(2026, 9, 30))
                        .MajorUnit = 10
                        .TickLabels.NumberFormat = "mm-dd"
                    End With
                End With
                processedCount = processedCount + 1
            End If
        End If
    Next wsData
    
    ' 4. 통합 차트(Combined Chart) 생성
    If rowCombined > 2 Then
        ' 블록명 순서로 정렬 (R110A(PP)와 R110A(PS)가 나란히 오도록 정렬됨)
        wsCombined.Range("A1:D" & rowCombined - 1).Sort Key1:=wsCombined.Range("A2"), Order1:=xlAscending, Header:=xlYes
        
        ' 차트 높이를 데이터 개수에 맞춰 넉넉히 설정 (800)
        Set chartObj = wsCombined.ChartObjects.Add(Left:=350, Top:=20, Width:=800, Height:=800)
        Set myChart = chartObj.Chart
        myChart.ChartType = xlBarStacked
        
        Do While myChart.SeriesCollection.Count > 0
            myChart.SeriesCollection(1).Delete
        Loop
        
        ' 시리즈 1: 투명 시작일 막대
        With myChart.SeriesCollection.NewSeries
            .Name = "Start Date"
            .XValues = wsCombined.Range("A2:A" & rowCombined - 1)
            .Values = wsCombined.Range("B2:B" & rowCombined - 1)
            .Format.Fill.Visible = msoFalse
            .Format.Line.Visible = msoFalse
        End With
        
        ' 시리즈 2: PP 기간 (주황색)
        With myChart.SeriesCollection.NewSeries
            .Name = "PP Schedule"
            .XValues = wsCombined.Range("A2:A" & rowCombined - 1)
            .Values = wsCombined.Range("C2:C" & rowCombined - 1)
            .Format.Fill.Visible = msoTrue
            .Format.Fill.ForeColor.RGB = RGB(237, 125, 49)
        End With
        
        ' 시리즈 3: PS 기간 (녹색)
        With myChart.SeriesCollection.NewSeries
            .Name = "PS Schedule"
            .XValues = wsCombined.Range("A2:A" & rowCombined - 1)
            .Values = wsCombined.Range("D2:D" & rowCombined - 1)
            .Format.Fill.Visible = msoTrue
            .Format.Fill.ForeColor.RGB = RGB(84, 130, 53)
        End With
        
        ' 통합 차트 설정
        With myChart
            .HasTitle = True
            .ChartTitle.Text = "배관 스풀(PP) & 파이프 서포트(PS) 통합 일정 현황"
            .HasLegend = True ' 어떤 색상이 PP/PS인지 알기 위해 범례 표시
            .Legend.Position = xlLegendPositionTop
            .Axes(xlCategory).ReversePlotOrder = True
            With .Axes(xlValue)
                .MinimumScale = CDbl(DateSerial(2026, 3, 1))
                .MaximumScale = CDbl(DateSerial(2026, 9, 30))
                .MajorUnit = 10
                .TickLabels.NumberFormat = "mm-dd"
            End With
        End With
        
        ' 완성된 Combined 시트를 가장 맨 앞으로 이동
        wsCombined.Move Before:=Sheets(1)
    End If
    
    Application.ScreenUpdating = True
    
    If processedCount > 0 Then
        MsgBox "개별 차트 " & processedCount & "개 및 통합 차트가 성공적으로 생성되었습니다!", vbInformation
    Else
        MsgBox "PP 또는 PS 데이터를 찾을 수 없습니다.", vbExclamation
    End If
End Sub
