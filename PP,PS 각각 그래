Sub CreateAllGanttCharts_PP_PS()
    Dim wsData As Worksheet
    Dim wsChart As Worksheet
    Dim dictStart As Object, dictEnd As Object
    Dim lastRow As Long, i As Long, rowOutput As Long
    Dim blockName As String
    Dim inPosDate As Date, weldDate As Date
    Dim varKey As Variant
    Dim chartObj As ChartObject
    Dim myChart As Chart
    Dim reportSheetName As String, chartTitle As String
    Dim processedCount As Integer
    
    processedCount = 0
    
    ' 1. 현재 엑셀 파일에 있는 모든 시트를 자동으로 돌아가며 확인합니다.
    For Each wsData In ActiveWorkbook.Worksheets
        
        ' 시트 이름에 "PP" 또는 "PS"가 포함되어 있고, 이미 결과물이 나온 "Gantt" 시트가 아닐 경우에만 작업 시작
        If (InStr(1, UCase(wsData.Name), "PP") > 0 Or InStr(1, UCase(wsData.Name), "PS") > 0) And InStr(1, UCase(wsData.Name), "GANTT") = 0 Then
            
            lastRow = wsData.Cells(wsData.Rows.Count, "B").End(xlUp).Row
            Set dictStart = CreateObject("Scripting.Dictionary")
            Set dictEnd = CreateObject("Scripting.Dictionary")
            
            ' 데이터 수집 로직 (B열: Block, D열: 시작일, F열: 완료일)
            For i = 2 To lastRow
                blockName = Trim(wsData.Cells(i, 2).Value)
                If blockName <> "" And IsDate(wsData.Cells(i, 4).Value) And IsDate(wsData.Cells(i, 6).Value) Then
                    inPosDate = CDate(wsData.Cells(i, 4).Value)
                    weldDate = CDate(wsData.Cells(i, 6).Value)
                    
                    If Not dictStart.Exists(blockName) Then
                        dictStart.Add blockName, inPosDate
                    Else
                        If inPosDate < dictStart(blockName) Then dictStart(blockName) = inPosDate
                    End If
                    
                    If Not dictEnd.Exists(blockName) Then
                        dictEnd.Add blockName, weldDate
                    Else
                        If weldDate > dictEnd(blockName) Then dictEnd(blockName) = weldDate
                    End If
                End If
            Next i
            
            ' 2. 유효한 데이터가 확인되면 해당 데이터의 차트 시트 생성
            If dictStart.Count > 0 Then
                
                ' PP/PS 구분하여 시트명 및 제목 자동 설정
                reportSheetName = Left(wsData.Name, 15) & "_Gantt"
                If InStr(1, UCase(wsData.Name), "PP") > 0 Then
                    chartTitle = "배관 스풀(PP) 작업 일정 현황"
                Else
                    chartTitle = "파이프 서포트(PS) 작업 일정 현황"
                End If
                
                ' 기존 시트 덮어쓰기 방지
                Application.DisplayAlerts = False
                On Error Resume Next
                Sheets(reportSheetName).Delete
                On Error GoTo 0
                Application.DisplayAlerts = True
                
                ' 새 시트 생성
                Set wsChart = Sheets.Add(After:=Sheets(Sheets.Count))
                wsChart.Name = reportSheetName
                
                ' 3. 요약 데이터 작성
                wsChart.Cells(1, 1).Value = "Block"
                wsChart.Cells(1, 2).Value = "Start Date"
                wsChart.Cells(1, 3).Value = "Duration"
                
                rowOutput = 2
                For Each varKey In dictStart.Keys
                    wsChart.Cells(rowOutput, 1).Value = varKey
                    wsChart.Cells(rowOutput, 2).Value = CDbl(dictStart(varKey))
                    wsChart.Cells(rowOutput, 2).NumberFormat = "yyyy-mm-dd"
                    wsChart.Cells(rowOutput, 3).Value = Application.WorksheetFunction.Max(1, dictEnd(varKey) - dictStart(varKey))
                    rowOutput = rowOutput + 1
                Next varKey
                
                wsChart.Range("A1:C" & rowOutput - 1).Sort Key1:=wsChart.Range("A2"), Order1:=xlAscending, Header:=xlYes
                
                ' 4. 차트 생성
                Set chartObj = wsChart.ChartObjects.Add(Left:=300, Top:=20, Width:=750, Height:=600)
                Set myChart = chartObj.Chart
                myChart.ChartType = xlBarStacked
                
                Do While myChart.SeriesCollection.Count > 0
                    myChart.SeriesCollection(1).Delete
                Loop
                
                ' 시리즈 1 (투명 막대)
                With myChart.SeriesCollection.NewSeries
                    .Name = "Start Date"
                    .XValues = wsChart.Range("A2:A" & rowOutput - 1)
                    .Values = wsChart.Range("B2:B" & rowOutput - 1)
                    .Format.Fill.Visible = msoFalse
                    .Format.Line.Visible = msoFalse
                End With
                
                ' 시리즈 2 (PP: 주황색, PS: 녹색)
                With myChart.SeriesCollection.NewSeries
                    .Name = "Duration"
                    .XValues = wsChart.Range("A2:A" & rowOutput - 1)
                    .Values = wsChart.Range("C2:C" & rowOutput - 1)
                    .Format.Fill.Visible = msoTrue
                    If InStr(1, UCase(wsData.Name), "PS") > 0 Then
                        .Format.Fill.ForeColor.RGB = RGB(84, 130, 53) ' 녹색
                    Else
                        .Format.Fill.ForeColor.RGB = RGB(237, 125, 49) ' 주황색
                    End If
                End With
                
                ' 5. 축 및 세부 설정
                With myChart
                    .HasTitle = True
                    .ChartTitle.Text = chartTitle
                    With .Axes(xlCategory)
                        .ReversePlotOrder = True
                    End With
                    With .Axes(xlValue)
                        .MinimumScale = CDbl(DateSerial(2026, 3, 1))
                        .MaximumScale = CDbl(DateSerial(2026, 9, 30))
                        .MajorUnit = 10
                        .TickLabels.NumberFormat = "mm-dd"
                    End With
                End With
                
                ' 성공 카운트 증가
                processedCount = processedCount + 1
            End If
        End If
    Next wsData
    
    ' 완료 메시지
    If processedCount > 0 Then
        MsgBox processedCount & "개의 간트 차트(PP, PS)가 각각 신규 시트에 성공적으로 생성되었습니다!", vbInformation
    Else
        MsgBox "데이터 시트를 찾을 수 없습니다. 시트명에 'PP'나 'PS'가 포함되어 있는지 확인해주세요.", vbExclamation
    End If
End Sub

