Sub UpdateDates_NewVersion()
    Dim wb As Workbook
    Set wb = ActiveWorkbook
    
    Dim ws As Worksheet
    Dim sheetList As String
    Dim reqSheets As Variant
    Dim sName As Variant
    
    ' 1. 현재 파일에 있는 모든 시트 이름 수집 (에러 진단용)
    For Each ws In wb.Sheets
        sheetList = sheetList & "[" & ws.Name & "] "
    Next ws
    
    ' 2. 필수 시트들이 존재하는지 검사 (대소문자, 띄어쓰기 무시)
    reqSheets = Array("PP", "PS", "SST", "PP-A", "PS-A", "SST-A")
    For Each sName In reqSheets
        If GetSheet(wb, CStr(sName)) Is Nothing Then
            MsgBox sName & " 시트를 찾을 수 없습니다!" & vbCrLf & vbCrLf & _
                   "▶ 현재 열려있는 파일의 실제 시트 목록:" & vbCrLf & sheetList & vbCrLf & vbCrLf & _
                   "이름이 미세하게 다르거나, 다른 엑셀 파일을 열어둔 채 실행한 것은 아닌지 확인해 주세요.", vbCritical, "시트 이름 오류"
            Exit Sub
        End If
    Next sName
    
    ' 3. Error_Log 시트 초기화 (기존에 있으면 삭제하고 새로 생성)
    Application.DisplayAlerts = False
    Dim wsLog As Worksheet
    Set wsLog = GetSheet(wb, "ERROR_LOG")
    If Not wsLog Is Nothing Then wsLog.Delete
    Application.DisplayAlerts = True
    
    Set wsLog = wb.Sheets.Add(After:=wb.Sheets(wb.Sheets.Count))
    wsLog.Name = "Error_Log"
    wsLog.Range("A1:E1").Value = Array("대상 시트", "태그 번호", "입력 날짜", "에러 종류", "상세 설명")
    wsLog.Range("A1:E1").Interior.Color = RGB(220, 230, 241)
    wsLog.Range("A1:E1").Font.Bold = True
    Dim logRow As Long
    logRow = 2
    
    ' 4. 본격적인 데이터 업데이트 작업 시작
    Dim pairs As Variant
    ' Array구조: Array(마스터시트, 업데이트시트, 날짜입력열)
    pairs = Array(Array("PP", "PP-A", "T"), Array("PS", "PS-A", "T"), Array("SST", "SST-A", "P"))
    
    Dim wsMaster As Worksheet, wsUpdate As Worksheet
    Dim targetCol As String
    Dim i As Integer, r As Long
    Dim lastRowUpd As Long, lastRowMaster As Long
    Dim tagVal As String, dateVal As Variant
    Dim foundCell As Range, targetCell As Range
    Dim isSuccess As Boolean
    
    For i = LBound(pairs) To UBound(pairs)
        Set wsMaster = GetSheet(wb, CStr(pairs(i)(0)))
        Set wsUpdate = GetSheet(wb, CStr(pairs(i)(1)))
        targetCol = CStr(pairs(i)(2))
        
        ' 기존 필터 및 배경색(노란색) 초기화
        If wsMaster.AutoFilterMode Then wsMaster.AutoFilterMode = False
        wsMaster.Columns(targetCol).Interior.Pattern = xlNone
        
        ' Update 시트 C열 제목 설정 및 글자색 초기화
        wsUpdate.Cells(1, 3).Value = "입력상태"
        wsUpdate.Columns("C").Font.ColorIndex = xlAutomatic
        
        lastRowUpd = wsUpdate.Cells(wsUpdate.Rows.Count, "A").End(xlUp).Row
        
        ' Update 시트 2행부터 순환
        For r = 2 To lastRowUpd
            isSuccess = False ' 매 행마다 성공 여부 초기화
            
            ' 값 가져오기 (수식 에러 방지)
            If Not IsError(wsUpdate.Cells(r, 1).Value) Then
                tagVal = Trim(CStr(wsUpdate.Cells(r, 1).Value))
            Else
                tagVal = ""
            End If
            dateVal = wsUpdate.Cells(r, 2).Value
            
            ' 태그 번호가 있는 경우만 실행
            If tagVal <> "" Then
                If IsError(dateVal) Or Trim(CStr(dateVal)) = "" Then
                    ' 날짜 누락 에러 로깅 (이 경우 C열에는 아무것도 적지 않고 넘어감)
                    Call WriteLog(wsLog, logRow, wsUpdate.Name, tagVal, "누락", "날짜 오류", "업데이트할 날짜가 비어있거나 올바르지 않습니다.")
                Else
                    ' B열에 날짜가 정상적으로 있을 때 로직 실행
                    ' 마스터 시트 D열에서 태그 찾기 (.Find 방식 사용)
                    Set foundCell = wsMaster.Columns("D").Find(What:=tagVal, LookAt:=xlWhole, MatchCase:=False)
                    
                    If foundCell Is Nothing Then
                        ' 태그를 못 찾음
                        Call WriteLog(wsLog, logRow, wsUpdate.Name, tagVal, dateVal, "태그 없음", wsMaster.Name & " 시트 D열에 해당 태그가 없습니다.")
                    Else
                        ' 태그를 찾았을 경우, 대상 셀 확인
                        Set targetCell = wsMaster.Cells(foundCell.Row, targetCol)
                        
                        If Trim(CStr(targetCell.Value)) <> "" Then
                            ' 이미 날짜가 있음 (덮어쓰기 금지)
                            Call WriteLog(wsLog, logRow, wsUpdate.Name, tagVal, dateVal, "덮어쓰기 금지", "이미 데이터(" & targetCell.Value & ")가 존재합니다.")
                        Else
                            ' ★ 정상 입력 및 노란색 칠하기
                            targetCell.Value = dateVal
                            targetCell.Interior.Color = vbYellow
                            isSuccess = True ' 정상 입력 성공
                        End If
                    End If
                    
                    ' ★ 날짜가 존재하여 처리를 시도한 경우에만 C열에 성공/실패 여부 기록
                    If isSuccess Then
                        wsUpdate.Cells(r, 3).Value = "입력"
                    Else
                        wsUpdate.Cells(r, 3).Value = "미입력"
                        wsUpdate.Cells(r, 3).Font.Color = vbRed ' 미입력은 눈에 띄게 빨간색으로 표시
                    End If
                    
                End If
            End If
        Next r
        
        ' 5. 노란색 필터링 적용 작업
        Set foundCell = wsMaster.Columns("D").Find(What:="TAG NO", LookAt:=xlWhole, MatchCase:=False)
        If Not foundCell Is Nothing Then
            Dim headerRow As Long, filterColIndex As Integer
            headerRow = foundCell.Row
            lastRowMaster = wsMaster.Cells(wsMaster.Rows.Count, "D").End(xlUp).Row
            filterColIndex = wsMaster.Columns(targetCol).Column
            
            ' 제목줄 아래로 데이터가 있을 경우 필터 적용
            If lastRowMaster >= headerRow Then
                wsMaster.Range(wsMaster.Cells(headerRow, 1), wsMaster.Cells(lastRowMaster, wsMaster.UsedRange.Columns.Count)).AutoFilter _
                    Field:=filterColIndex, Criteria1:=vbYellow, Operator:=xlFilterCellColor
            End If
        End If
        
        ' C열 너비 자동 맞춤
        wsUpdate.Columns("C").AutoFit
    Next i
    
    wsLog.Columns.AutoFit
    MsgBox "데이터 업데이트 작업이 완료되었습니다." & vbCrLf & "에러 내역은 'Error_Log' 시트를 확인해 주세요.", vbInformation, "작업 성공"

End Sub

' [보조 함수 1] 띄어쓰기나 대소문자가 달라도 시트를 안전하게 찾아주는 함수
Function GetSheet(wb As Workbook, shtName As String) As Worksheet
    Dim ws As Worksheet
    For Each ws In wb.Sheets
        If UCase(Trim(ws.Name)) = UCase(Trim(shtName)) Then
            Set GetSheet = ws
            Exit Function
        End If
    Next ws
    Set GetSheet = Nothing
End Function

' [보조 함수 2] 로그 기록용 함수
Sub WriteLog(ws As Worksheet, ByRef r As Long, sName As String, tag As String, dt As Variant, errType As String, detail As String)
    ws.Cells(r, 1).Value = sName
    ws.Cells(r, 2).Value = tag
    ws.Cells(r, 3).Value = dt
    ws.Cells(r, 4).Value = errType
    ws.Cells(r, 5).Value = detail
    r = r + 1
End Sub
