Sub CreateGroupedGanttCharts_Final()
    Dim ws As Worksheet
    Dim dictBlocks As Object
    Dim dictPPStart As Object, dictPPEnd As Object
    Dim dictPSStart As Object, dictPSEnd As Object
    Dim dictESStart As Object, dictESEnd As Object
    Dim lastRow As Long, i As Long, rowOut As Long
    Dim bName As String, dtStart As Date, dtEnd As Date
    Dim isPP As Boolean, isPS As Boolean, isES As Boolean
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    ' 1. 기존 간트 차트 시트 모두 삭제 (초기화)
    For Each ws In ActiveWorkbook.Worksheets
        If InStr(1, UCase(ws.Name), "GANTT") > 0 Then ws.Delete
    Next ws
    Application.DisplayAlerts = True
    
    ' 2. 데이터 저장을 위한 딕셔너리 세팅
    Set dictBlocks = CreateObject("Scripting.Dictionary")
    Set dictPPStart = CreateObject("Scripting.Dictionary"): Set dictPPEnd = CreateObject("Scripting.Dictionary")
    Set dictPSStart = CreateObject("Scripting.Dictionary"): Set dictPSEnd = CreateObject("Scripting.Dictionary")
    Set dictESStart = CreateObject("Scripting.Dictionary"): Set dictESEnd = CreateObject("Scripting.Dictionary")
    
    ' 3. 모든 데이터 취합
    For Each ws In ActiveWorkbook.Worksheets
        isPP = InStr(1, UCase(ws.Name), "PP") > 0
        isPS = InStr(1, UCase(ws.Name), "PS") > 0
        isES = InStr(1, UCase(ws.Name), "ES") > 0
        
        If isPP Or isPS Or isES Then
            lastRow = ws.Cells(ws.Rows.Count, "B").End(xlUp).Row
            For i = 2 To lastRow
                bName = Trim(ws.Cells(i, 2).Value)
                If bName <> "" And IsDate(ws.Cells(i, 4).Value) And IsDate(ws.Cells(i, 6).Value) Then
                    dtStart = CDate(ws.Cells(i, 4).Value)
                    dtEnd = CDate(ws.Cells(i, 6).Value)
                    
                    ' 전체 블록명 리스트 수집
                    If Not dictBlocks.Exists(bName) Then dictBlocks.Add bName, 1
                    
                    ' 공종별 데이터 갱신 (가장 빠른 시작일, 가장 늦은 종료일)
                    If isPP Then
                        If Not dictPPStart.Exists(bName) Then dictPPStart.Add bName, dtStart Else If dtStart < dictPPStart(bName) Then dictPPStart(bName) = dtStart
                        If Not dictPPEnd.Exists(bName) Then dictPPEnd.Add bName, dtEnd Else If dtEnd > dictPPEnd(bName) Then dictPPEnd(bName) = dtEnd
                    ElseIf isPS Then
                        If Not dictPSStart.Exists(bName) Then dictPSStart.Add bName, dtStart Else If dtStart < dictPSStart(bName) Then dictPSStart(bName) = dtStart
                        If Not dictPSEnd.Exists(bName) Then dictPSEnd.Add bName, dtEnd Else If dtEnd > dictPSEnd(bName) Then dictPSEnd(bName) = dtEnd
                    ElseIf isES Then
                        If Not dictESStart.Exists(bName) Then dictESStart.Add bName, dtStart Else If dtStart < dictESStart(bName) Then dictESStart(bName) = dtStart
                        If Not dictESEnd.Exists(bName) Then dictESEnd.Add bName, dtEnd Else If dtEnd > dictESEnd(bName) Then dictESEnd(bName) = dtEnd
                    End If
                End If
            Next i
        End If
    Next ws
    
    Dim numBlocks As Integer
    numBlocks = dictBlocks.Count
    If numBlocks = 0 Then
        MsgBox "유효한 데이터가 없습니다.", vbExclamation
        Exit Sub
    End If
    
    ' 4. 블록명을 A->Z 순서로 정렬 (버블 정렬)
    Dim blockArr() As String
    ReDim blockArr(1 To numBlocks)
    Dim k As Variant, idx As Integer: idx = 1
    For Each k In dictBlocks.Keys
        blockArr(idx) = CStr(k)
        idx = idx + 1
    Next k
    
    Dim j As Integer, temp As String
    For i = 1 To numBlocks - 1
        For j = i + 1 To numBlocks
            If blockArr(i) > blockArr(j) Then
                temp = blockArr(i): blockArr(i) = blockArr(j): blockArr(j) = temp
            End If
        Next j
    Next i
    
    ' ==============================================================
    ' 5. 통합 간트 차트 (Combined) 시트 생성
    ' ==============================================================
    Dim wsCombined As Worksheet
    Set wsCombined = Sheets.Add(Before:=Sheets(1))
    wsCombined.Name = "Combined_Gantt"
    
    ' 다중 수준 데이터 배치를 위한 헤더 설정
    wsCombined.Cells(1, 1).Value = "Block"
    wsCombined.Cells(1, 2).Value = "Type"
    wsCombined.Cells(1, 3).Value = "Start Date"
    wsCombined.Cells(1, 4).Value = "PP Duration"
    wsCombined.Cells(1, 5).Value = "PS Duration"
    wsCombined.Cells(1, 6).Value = "ES Duration"
    
    rowOut = 2
    Dim firstRow As Boolean
    
    For i = 1 To numBlocks
        bName = blockArr(i)
        firstRow = True
        
        ' PP 데이터 기록
        If dictPPStart.Exists(bName) Then
            If firstRow Then wsCombined.Cells(rowOut, 1).Value = bName: firstRow = False
            wsCombined.Cells(rowOut, 2).Value = "PP"
            wsCombined.Cells(rowOut, 3).Value = CDbl(dictPPStart(bName))
            wsCombined.Cells(rowOut, 4).Value = Application.Max(1, dictPPEnd(bName) - dictPPStart(bName))
            rowOut = rowOut + 1
        End If
        
        ' PS 데이터 기록
        If dictPSStart.Exists(bName) Then
            If firstRow Then wsCombined.Cells(rowOut, 1).Value = bName: firstRow = False
            wsCombined.Cells(rowOut, 2).Value = "PS"
            wsCombined.Cells(rowOut, 3).Value = CDbl(dictPSStart(bName))
            wsCombined.Cells(rowOut, 5).Value = Application.Max(1, dictPSEnd(bName) - dictPSStart(bName))
            rowOut = rowOut + 1
        End If
        
        ' ES 데이터 기록
        If dictESStart.Exists(bName) Then
            If firstRow Then wsCombined.Cells(rowOut, 1).Value = bName: firstRow = False
            wsCombined.Cells(rowOut, 2).Value = "ES"
            wsCombined.Cells(rowOut, 3).Value = CDbl(dictESStart(bName))
            wsCombined.Cells(rowOut, 6).Value = Application.Max(1, dictESEnd(bName) - dictESStart(bName))
            rowOut = rowOut + 1
        End If
    Next i
    wsCombined.Columns("C:C").NumberFormat = "yyyy-mm-dd"
    
    ' 통합 차트 생성
    Dim chartObj As ChartObject, myChart As Chart
    Set chartObj = wsCombined.ChartObjects.Add(Left:=400, Top:=20, Width:=850, Height:=1000)
    Set myChart = chartObj.Chart
    myChart.ChartType = xlBarStacked
    
    Do While myChart.SeriesCollection.Count > 0: myChart.SeriesCollection(1).Delete: Loop
    
    ' (1) 투명 시작일 막대
    With myChart.SeriesCollection.NewSeries
        .Name = "Start Date"
        .XValues = wsCombined.Range("A2:B" & rowOut - 1) ' A와 B열을 동시에 잡아 Y축 그룹화 자동 적용
        .Values = wsCombined.Range("C2:C" & rowOut - 1)
        .Format.Fill.Visible = msoFalse: .Format.Line.Visible = msoFalse
    End With
    
    ' (2) PP 막대 (주황색)
    With myChart.SeriesCollection.NewSeries
        .Name = "PP Schedule"
        .XValues = wsCombined.Range("A2:B" & rowOut - 1)
        .Values = wsCombined.Range("D2:D" & rowOut - 1)
        .Format.Fill.Visible = msoTrue
        .Format.Fill.ForeColor.RGB = RGB(237, 125, 49)
    End With
    
    ' (3) PS 막대 (녹색)
    With myChart.SeriesCollection.NewSeries
        .Name = "PS Schedule"
        .XValues = wsCombined.Range("A2:B" & rowOut - 1)
        .Values = wsCombined.Range("E2:E" & rowOut - 1)
        .Format.Fill.Visible = msoTrue
        .Format.Fill.ForeColor.RGB = RGB(84, 130, 53)
    End With
    
    ' (4) ES 막대 (파란색)
    With myChart.SeriesCollection.NewSeries
        .Name = "ES Schedule"
        .XValues = wsCombined.Range("A2:B" & rowOut - 1)
        .Values = wsCombined.Range("F2:F" & rowOut - 1)
        .Format.Fill.Visible = msoTrue
        .Format.Fill.ForeColor.RGB = RGB(68, 114, 196)
    End With
    
    ' 통합 차트 서식 및 가로 구분선 설정
    With myChart
        .HasTitle = True
        .ChartTitle.Text = "PP, PS, ES 그룹별 통합 일정 현황"
        .HasLegend = True
        .Legend.Position = xlLegendPositionTop
        
        ' 막대 두께 조정 (보기 좋게 뭉치게 함)
        .ChartGroups(1).GapWidth = 60
        
        With .Axes(xlCategory)
            .ReversePlotOrder = True
            ' ⭐️ 핵심: 그룹과 그룹 사이에 명확한 가로 구분선 추가
            .HasMajorGridlines = True
            .MajorGridlines.Format.Line.Visible = msoTrue
            .MajorGridlines.Format.Line.ForeColor.RGB = RGB(160, 160, 160)
            .MajorGridlines.Format.Line.Weight = 1.25
            .MajorGridlines.Format.Line.DashStyle = msoLineSolid
        End With
        
        With .Axes(xlValue)
            .MinimumScale = CDbl(DateSerial(2026, 3, 1))
            .MaximumScale = CDbl(DateSerial(2026, 9, 30))
            .MajorUnit = 10
            .TickLabels.NumberFormat = "mm-dd"
        End With
    End With
    
    ' ==============================================================
    ' 6. 개별 공종 차트 생성 (자동 반복)
    ' ==============================================================
    Dim typeName As Variant, arrTypes As Variant
    Dim curDictStart As Object, curDictEnd As Object
    Dim curColor As Long, curTitle As String
    Dim wsIndiv As Worksheet, rIdx As Long
    
    arrTypes = Array("PP", "PS", "ES")
    
    For Each typeName In arrTypes
        If typeName = "PP" Then
            Set curDictStart = dictPPStart: Set curDictEnd = dictPPEnd: curColor = RGB(237, 125, 49): curTitle = "배관 스풀(PP) 작업 일정"
        ElseIf typeName = "PS" Then
            Set curDictStart = dictPSStart: Set curDictEnd = dictPSEnd: curColor = RGB(84, 130, 53): curTitle = "파이프 서포트(PS) 작업 일정"
        Else
            Set curDictStart = dictESStart: Set curDictEnd = dictESEnd: curColor = RGB(68, 114, 196): curTitle = "ES 작업 일정"
        End If
        
        If curDictStart.Count > 0 Then
            Set wsIndiv = Sheets.Add(After:=Sheets(Sheets.Count))
            wsIndiv.Name = typeName & "_Gantt"
            wsIndiv.Cells(1, 1).Value = "Block": wsIndiv.Cells(1, 2).Value = "Start Date": wsIndiv.Cells(1, 3).Value = "Duration"
            
            rIdx = 2
            For i = 1 To numBlocks
                bName = blockArr(i)
                If curDictStart.Exists(bName) Then
                    wsIndiv.Cells(rIdx, 1).Value = bName
                    wsIndiv.Cells(rIdx, 2).Value = CDbl(curDictStart(bName))
                    wsIndiv.Cells(rIdx, 2).NumberFormat = "yyyy-mm-dd"
                    wsIndiv.Cells(rIdx, 3).Value = Application.Max(1, curDictEnd(bName) - curDictStart(bName))
                    rIdx = rIdx + 1
                End If
            Next i
            
            Set chartObj = wsIndiv.ChartObjects.Add(Left:=300, Top:=20, Width:=750, Height:=600)
            Set myChart = chartObj.Chart
            myChart.ChartType = xlBarStacked
            
            Do While myChart.SeriesCollection.Count > 0: myChart.SeriesCollection(1).Delete: Loop
            
            With myChart.SeriesCollection.NewSeries
                .Name = "Start Date"
                .XValues = wsIndiv.Range("A2:A" & rIdx - 1)
                .Values = wsIndiv.Range("B2:B" & rIdx - 1)
                .Format.Fill.Visible = msoFalse: .Format.Line.Visible = msoFalse
            End With
            With myChart.SeriesCollection.NewSeries
                .Name = "Duration"
                .XValues = wsIndiv.Range("A2:A" & rIdx - 1)
                .Values = wsIndiv.Range("C2:C" & rIdx - 1)
                .Format.Fill.Visible = msoTrue
                .Format.Fill.ForeColor.RGB = curColor
            End With
            With myChart
                .HasTitle = True
                .ChartTitle.Text = curTitle
                .Axes(xlCategory).ReversePlotOrder = True
                With .Axes(xlValue)
                    .MinimumScale = CDbl(DateSerial(2026, 3, 1))
                    .MaximumScale = CDbl(DateSerial(2026, 9, 30))
                    .MajorUnit = 10
                    .TickLabels.NumberFormat = "mm-dd"
                End With
            End With
        End If
    Next typeName

    Application.ScreenUpdating = True
    MsgBox "그룹화된 3중 통합 차트 및 개별 차트 생성이 완료되었습니다!", vbInformation
End Sub
